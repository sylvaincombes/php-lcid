{
  "name": "sylvaincombes/php-lcid",
  "description": "Library to find iso language code from a microsoft LCID",
  "keywords": ["php", "lcid", "locale", "icu", "intl"],
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Sylvain Combes",
      "email": "combes.sylvain@gmail.com"
    }
  ],
  "repositories": [
    {"type": "composer", "url": "https://packagist.org"}
  ],
  "autoload": {
    "psr-4": {
      "SylvainCombes\\": "src/SylvainCombes"
    }
  },
  "require": {
    "php": ">=8.4",
    "opis/json-schema": "^2.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.0",
    "ext-intl": "*",
    "symfony/intl": "^8.0",
    "symfony/console": "^8.0",
    "friendsofphp/php-cs-fixer": "^3.0",
    "phpstan/phpstan": "^2.1",
    "vimeo/psalm": "^6.16"
  },
  "scripts": {
    "test": "./vendor/bin/phpunit --colors=always",
    "lint": "./vendor/bin/php-cs-fixer fix --dry-run --diff",
    "fix": "./vendor/bin/php-cs-fixer fix",
    "phpstan": "./vendor/bin/phpstan analyse --no-progress",
    "psalm": "./vendor/bin/psalm",
    "check": ["@test", "@lint", "@phpstan", "@psalm"]
  }
}
